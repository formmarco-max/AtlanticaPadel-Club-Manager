// Modelo de dados do Atlantica Padel Club Manager.
//
// Entidades:
// - Club
// - Role
// - User
// - Member
// - Coach
// - Court
// - Reservation

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Club {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @unique @db.VarChar(150)
  slug           String   @unique @db.VarChar(150)
  email          String?  @db.VarChar(255)
  phone          String?  @db.VarChar(30)
  website        String?  @db.VarChar(255)
  description    String?  @db.Text
  taxNumber      String?  @map("tax_number") @db.VarChar(20)
  address        String?  @db.VarChar(255)
  postalCode     String?  @map("postal_code") @db.VarChar(20)
  city           String?  @db.VarChar(100)
  district       String?  @db.VarChar(100)
  country        String?  @default("Portugal") @db.VarChar(100)
  logoUrl        String?  @map("logo_url") @db.VarChar(500)
  primaryColor   String?  @map("primary_color") @db.VarChar(20)
  secondaryColor String?  @map("secondary_color") @db.VarChar(20)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  users        User[]
  members      Member[]
  coaches      Coach[]
  courts       Court[]
  reservations Reservation[]

  @@map("clubs")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("roles")
}

model User {
  id String @id @default(uuid()) @db.Uuid

  clubId String @map("club_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  email        String @unique @db.VarChar(255)
  passwordHash String @map("password_hash") @db.VarChar(255)
  firstName    String @map("first_name") @db.VarChar(100)
  lastName     String @map("last_name") @db.VarChar(100)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Restrict)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  member Member?
  coach  Coach?

  @@index([clubId])
  @@index([roleId])
  @@map("users")
}

model Member {
  id String @id @default(uuid()) @db.Uuid

  clubId String  @map("club_id") @db.Uuid
  userId String? @unique @map("user_id") @db.Uuid

  membershipNumber String @unique @map("membership_number") @db.VarChar(30)

  firstName String  @map("first_name") @db.VarChar(100)
  lastName  String  @map("last_name") @db.VarChar(100)
  email     String? @db.VarChar(255)
  phone     String? @db.VarChar(30)

  birthDate DateTime? @map("birth_date") @db.Date
  joinDate  DateTime  @default(now()) @map("join_date") @db.Date

  notes String? @db.Text

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Restrict)

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  reservations Reservation[]

  @@index([clubId])
  @@map("members")
}

model Coach {
  id String @id @default(uuid()) @db.Uuid

  employeeNumber String? @unique @map("employee_number") @db.VarChar(30)

  clubId String  @map("club_id") @db.Uuid
  userId String? @unique @map("user_id") @db.Uuid

  firstName String @map("first_name") @db.VarChar(100)
  lastName  String @map("last_name") @db.VarChar(100)

  email String? @db.VarChar(255)
  phone String? @db.VarChar(30)

  specialization String? @db.VarChar(150)
  biography      String? @db.Text

  hireDate DateTime? @map("hire_date") @db.Date

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  club Club  @relation(fields: [clubId], references: [id], onDelete: Restrict)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clubId])
  @@index([isActive])
  @@map("coaches")
}

model Court {
  id String @id @default(uuid()) @db.Uuid

  clubId String @map("club_id") @db.Uuid

  name        String  @db.VarChar(100)
  description String? @db.Text
  location    String? @db.VarChar(150)

  surfaceType CourtSurfaceType @default(ARTIFICIAL_GRASS) @map("surface_type")
  courtType   CourtType        @default(DOUBLES) @map("court_type")
  environment CourtEnvironment @default(INDOOR)

  hourlyPrice Decimal? @map("hourly_price") @db.Decimal(10, 2)

  openingTime String @default("08:00") @map("opening_time") @db.VarChar(5)
  closingTime String @default("23:00") @map("closing_time") @db.VarChar(5)

  defaultReservationDuration Int @default(90) @map("default_reservation_duration")
  reservationInterval        Int @default(0) @map("reservation_interval")

  hasLighting Boolean @default(true) @map("has_lighting")

  isUnderMaintenance Boolean @default(false) @map("is_under_maintenance")
  maintenanceNotes   String? @map("maintenance_notes") @db.Text

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  club         Club          @relation(fields: [clubId], references: [id], onDelete: Restrict)
  reservations Reservation[]

  @@unique([clubId, name])
  @@index([clubId])
  @@index([isActive])
  @@map("courts")
}

model Reservation {
  id String @id @default(uuid()) @db.Uuid

  clubId   String @map("club_id") @db.Uuid
  courtId  String @map("court_id") @db.Uuid
  memberId String @map("member_id") @db.Uuid

  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")

  status ReservationStatus @default(CONFIRMED)

  totalPrice Decimal? @map("total_price") @db.Decimal(10, 2)

  notes              String?   @db.Text
  cancellationReason String?   @map("cancellation_reason") @db.Text
  cancelledAt        DateTime? @map("cancelled_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  club   Club   @relation(fields: [clubId], references: [id], onDelete: Restrict)
  court  Court  @relation(fields: [courtId], references: [id], onDelete: Restrict)
  member Member @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@index([clubId])
  @@index([courtId])
  @@index([memberId])
  @@index([courtId, startTime, endTime])
  @@index([status])
  @@map("reservations")
}

enum CourtSurfaceType {
  ARTIFICIAL_GRASS
  CONCRETE
  SYNTHETIC
  OTHER
}

enum CourtType {
  SINGLES
  DOUBLES
}

enum CourtEnvironment {
  INDOOR
  OUTDOOR
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}
